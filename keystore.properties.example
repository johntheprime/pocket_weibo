# Copy to keystore.properties (gitignored) at the repo root next to release.keystore.
# Generate a keystore once, for example:
#   keytool -genkeypair -v -keystore release.keystore -alias pocketweibo \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass YOUR_STORE_PASSWORD -keypass YOUR_KEY_PASSWORD \
#     -dname "CN=PocketWeibo, OU=Mobile, O=PocketWeibo, L=NA, ST=NA, C=US"
#
# GitHub Actions: set secrets RELEASE_KEYSTORE_BASE64 (base64 of release.keystore),
# RELEASE_STORE_PASSWORD, RELEASE_KEY_PASSWORD, RELEASE_KEY_ALIAS (e.g. pocketweibo).

storeFile=release.keystore
storePassword=CHANGE_ME
keyAlias=pocketweibo
keyPassword=CHANGE_ME
